{
  "name": "bedrock-agent-core-operations-hub-mcp",
  "version": "3.0.0",
  "description": "Bedrock AgentCore Operations Hub — Distributed MCP Architecture. 11 MCP Services, episodic memory, L2 Detective sub-agent, and a Health Dashboard.",
  "author": "Palamkunnel Sujith <sujithpvarghese@gmail.com>",
  "main": "dist/agent.js",
  "scripts": {
    "build": "tsc",
    "deploy": "sls deploy",
    "eval": "tsx src/evaluator.ts",
    "dev:agent": "tsx src/agent.ts",
    "dev:inventory": "tsx src/mcp-server/InventoryService.ts",
    "dev:webdb": "tsx src/mcp-server/WebDatabaseService.ts",
    "dev:status": "tsx src/mcp-server/status-hub.ts",
    "dev:l2": "tsx src/mcp-server/L2DetectiveService.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agent-runtime": "^3.1018.0",
    "@aws-sdk/client-bedrock-agentcore": "^3.1018.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1018.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1022.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@strands-agents/sdk": "^1.0.0-rc.1",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "serverless": "^4.4.19",
    "serverless-esbuild": "^1.52.0",
    "tsx": "^4.19.1",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "zod": "$zod"
  }
}
